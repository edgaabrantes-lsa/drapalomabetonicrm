{
  "name": "DossieImagem",
  "type": "object",
  "properties": {
    "patient_id": {
      "type": "string"
    },
    "patient_name": {
      "type": "string"
    },
    "categoria": {
      "type": "string",
      "enum": [
        "antes",
        "depois",
        "analise_facial",
        "evolucao",
        "intercorrencia",
        "documento_clinico",
        "outros"
      ],
      "default": "outros"
    },
    "titulo": {
      "type": "string"
    },
    "descricao": {
      "type": "string"
    },
    "procedimento_vinculado": {
      "type": "string"
    },
    "file_url": {
      "type": "string"
    },
    "file_name": {
      "type": "string"
    },
    "file_type": {
      "type": "string"
    },
    "data_upload": {
      "type": "string",
      "format": "date-time"
    },
    "uploaded_by": {
      "type": "string"
    },
    "portal_visible": {
      "type": "boolean",
      "default": false,
      "description": "Se a imagem deve aparecer no Portal da Paciente"
    },
    "portal_category": {
      "type": "string",
      "description": "Categoria de exibi\u00e7\u00e3o no portal (ex.: antes, depois, evolucao)"
    },
    "patient_note": {
      "type": "string",
      "description": "Nota da paciente ao enviar foto de evolu\u00e7\u00e3o"
    }
  },
  "required": [
    "patient_id",
    "categoria",
    "file_url"
  ],
  "rls": {
    "create": {
      "$or": [
        {
          "created_by_id": "{{user.id}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "read": {
      "$or": [
        {
          "created_by_id": "{{user.id}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "update": {
      "$or": [
        {
          "created_by_id": "{{user.id}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "delete": {
      "$or": [
        {
          "created_by_id": "{{user.id}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    }
  }
}